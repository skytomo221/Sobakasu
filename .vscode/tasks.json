{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Sobakasu: Build Compiler",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/Compiler/Sobakasu.csproj"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Sobakasu: Test Compiler",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/Compiler/Tests/Tests.csproj"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
